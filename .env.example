# Copy this file to .env and fill in the values
# cp .env.example .env

# ══════════════════════════════════════════════════════
# 部署时必改：服务器公网地址（协议 + 域名或 IP，不含路径）
# 端口固定为 3000，不需要修改其他任何 URL 配置。示例：
#   本地开发：PUBLIC_URL=http://localhost:3000
#   服务器IP：PUBLIC_URL=http://123.45.67.89:3000
#   自定域名：PUBLIC_URL=https://cau.example.com
# ══════════════════════════════════════════════════════
PUBLIC_URL=http://localhost:3000

# ── 数据库 ──────────────────────────────────────────
POSTGRES_USER=root
POSTGRES_PASSWORD=
POSTGRES_DB=postgres

# ── Better Auth ─────────────────────────────────────
# openssl rand -base64 32
BETTER_AUTH_SECRET=

# ── AI 模型接口 ──────────────────────────────────────
OPENAI_API_BASE_URL=
OPENAI_API_MODEL=
OPENAI_API_KEY=

# ── 手册 PDF（可选）─────────────────────────────────
# 上传手册后填写完整 URL，欢迎语会自动附上链接
# CAU_MANUAL_PDF_URL=https://your-server/manual.pdf

# ── 对外端口（默认 3000，一般不需要改）──────────────
# GATEWAY_PORT=3000
