# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# Bot Agent 工作区等（含 .data/wechatbot/<userId>/）
.data/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env

# pi MCP config (contains secrets)
.pi/mcp.json

# pi 运行时缓存（服务器自动生成，不提交）
.cache/
packages/work-server/.pi/cache/
packages/work-server/.pi/skills/**/__pycache__/
packages/work-server/.pi/skills/*/__pycache__/

# Claude Code worktrees（工具自动生成，不提交）
.claude/

# 参观资料（爬取的原始 HTML，仅供本地参考，不提交）
参观资料/

# 临时 / 本地素材
cauclaw.png

# vercel
.vercel

# large media files
*.mp4
*.mov
*.avi

# typescript
*.tsbuildinfo
next-env.d.ts


# python
__pycache__/


*.db