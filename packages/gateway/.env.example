# ══════════════════════════════════════════════════════
# 部署时必改：服务器公网地址（协议 + 域名或 IP，不含路径）
# 端口固定为 3000，不会变。示例：
#   本地开发：PUBLIC_URL=http://localhost:3000
#   服务器IP：PUBLIC_URL=http://123.45.67.89:3000
#   自定域名：PUBLIC_URL=https://cau.example.com
# docker-compose 中 BETTER_AUTH_URL / NEXT_PUBLIC_APP_URL /
# BETTER_AUTH_TRUSTED_ORIGINS 均由此变量自动派生。
# ══════════════════════════════════════════════════════
PUBLIC_URL=http://localhost:3000

# ── 数据库 ──────────────────────────────────────────
# Docker Compose 中由 compose 文件自动构造，本地开发时才需手动填写
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/cau_claw

# ── Better Auth ─────────────────────────────────────
# openssl rand -base64 32
BETTER_AUTH_SECRET=

# 以下三项在 Docker Compose 部署时由 PUBLIC_URL 自动派生，无需手动填写
# 本地开发（不走 compose）时才需要手动设置：
# BETTER_AUTH_URL=http://localhost:3000
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000

# ── AI 模型接口 ──────────────────────────────────────
OPENAI_API_BASE_URL=http://127.0.0.1:18000/v1
OPENAI_API_MODEL=sn
OPENAI_API_KEY=

# ── 手册 PDF（可选）─────────────────────────────────
# 上传手册后填写完整 URL，欢迎语会自动附上链接
# CAU_MANUAL_PDF_URL=https://your-server/manual.pdf

# ── 微信 Bot ─────────────────────────────────────────
# 微信 Bot 存储目录（默认 ~/.wechatbot）
# WECHATBOT_STORAGE_DIR=

# ── 本地开发独立后台（不走 compose 时才需要）────────
# BACKGROUND_WORKER_URL=http://127.0.0.1:3100
# WORKER_INTERNAL_TOKEN=
# WORKER_PORT=3100
# WORKER_HOST=0.0.0.0
